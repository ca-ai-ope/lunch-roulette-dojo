#!/bin/sh

# ============================================================
# Pre-commit Hook — AI駆動開発 品質ゲート（研修版）
# ============================================================
# AIが書いたコードをcommitする前に自動で品質チェックを実行。
# 「AIの出力を信頼せず検査する」をスローガンではなく仕組みにする。
#
# ステップ:
#   1. TypeScript型チェック: 型安全性の構造的保証
#   2. コード品質チェック: console.log / any型 / 巨大ファイル検出
# ============================================================

echo "🔍 Pre-commit: 品質ゲート実行中..."

# Step 1: TypeScript型チェック
echo ""
echo "📐 [1/2] TypeScript 型チェック..."
npx tsc --noEmit --pretty
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 型チェック失敗: 型エラーを修正してからコミットしてください"
  exit 1
fi
echo "✅ 型チェック通過"

# Step 2: コード品質チェック（console.log / any型 / 巨大ファイル）
echo ""
echo "🔎 [2/2] コード品質チェック..."
node ./scripts/check-code.mjs
if [ $? -ne 0 ]; then
  echo ""
  echo "❌ 品質チェック失敗: 上記の問題を修正してからコミットしてください"
  exit 1
fi

echo ""
echo "✅ Pre-commit: 全チェック通過！"
